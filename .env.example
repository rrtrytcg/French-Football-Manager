# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# Redis (optional - for scaling across multiple instances)
#REDIS_URL=redis://localhost:6379

# Room Configuration
ROOM_TTL_MINUTES=120
MAX_PLAYERS_PER_ROOM=40

# Game Balance (optional - defaults shown)
BASE_REWARD=50
BASE_UPGRADE_COST=100
BONUS_STREAK=5
BONUS_DURATION_MS=30000
MATCH_INTERVAL_MS=300000
MATCH_SIM_DURATION_MS=20000
POINTS_WIN=3
POINTS_DRAW=1
POINTS_LOSS=0

# Monitoring (optional)
#SENTRY_DSN=https://xxx@sentry.io/xxx
